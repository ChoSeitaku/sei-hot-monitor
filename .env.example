# OpenRouter API key for AI classification and summary (optional)
OPENROUTER_API_KEY=your_openrouter_key_here

# DeepSeek API key for AI hotspot verification and summary
DEEPSEEK_API_KEY=your_deepseek_key_here

# TwitterAPI.io API key for X/Twitter search
TWITTERAPI_KEY=your_twitterapi_key_here

# SMTP settings for optional email notification
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_RECIPIENTS=you@example.com

# VAPID keys for browser push notifications (optional)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Optional server port
PORT=4000
